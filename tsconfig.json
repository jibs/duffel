{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "outDir": "src/frontend/js",
    "rootDir": "src/frontend/ts",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "declaration": false,
    "sourceMap": false,
    "skipLibCheck": true
  },
  "include": ["src/frontend/ts/**/*.ts"]
}
